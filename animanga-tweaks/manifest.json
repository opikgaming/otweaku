{
  "manifest_version": 3,
  "name": "AniManga Tweaks",
  "version": "1.0",
  "description": "Tweaks for Anime & Manga Websties.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
	"content_scripts": [
	  {
		"matches": ["<all_urls>"],
		"js": ["content_scripts/frame_relay.js"],
		"all_frames": true,
		"run_at": "document_idle"
	  },
	  {
		"matches": ["<all_urls>"],
		"js": ["content_scripts/shared.js", "content_scripts/anime.js", "content_scripts/manga.js"],
		"run_at": "document_idle"
	  }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}